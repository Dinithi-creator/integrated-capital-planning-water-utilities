      <svg class="nav-logo" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="6" fill="#2d1580"/>
        <path d="M7 23 C7 23 9.5 11 16 11 C22.5 11 25 23 25 23" stroke="#8b5cf6" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <circle cx="16" cy="9" r="2.5" fill="#00d4c8"/>
        <path d="M12 23 L16 16 L20 23" stroke="#00d4c8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
      <div>
        <div class="nav-brand-name">IFS Copperleaf</div>
        <div class="nav-brand-sub">Water Campaign 2026</div>
      </div>
    </div>
    <div class="nav-sep"></div>
    <div class="nav-links">
      <a href="#overview">Overview</a>
