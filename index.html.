<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IFS Copperleaf – Water & Wastewater Campaign 2026</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;background:#0e0630;color:#fff;-webkit-font-smoothing:antialiased;line-height:1.6}
a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}

:root{
  --purple-deep:#0e0630;
  --purple-dark:#1a0a4a;
  --purple-mid:#2d1580;
  --purple-bright:#6c3bff;
  --purple-accent:#8b5cf6;
  --purple-light:#c4b5fd;
  --purple-pale:#f3f0ff;
  --teal:#00d4c8;
  --white:#ffffff;
  --card-bg:#ffffff;
  --card-border:rgba(108,59,255,0.15);
  --text-dark:#1a0a4a;
  --text-muted:#64748b;
  --radius:8px;
  --radius-lg:14px;
  --shadow:0 2px 12px rgba(108,59,255,0.18);
  --shadow-hover:0 8px 32px rgba(108,59,255,0.32);
}

/* ── NAV ── */
.nav{position:sticky;top:0;z-index:200;background:rgba(14,6,48,0.96);backdrop-filter:blur(10px);border-bottom:1px solid rgba(108,59,255,0.25)}
.nav-inner{max-width:1220px;margin:0 auto;display:flex;align-items:center;padding:0 1.25rem;gap:1rem}
.nav-brand{display:flex;align-items:center;gap:9px;padding:11px 0;flex-shrink:0}
.nav-logo{width:32px;height:32px;flex-shrink:0}
.nav-brand-name{font-size:13px;font-weight:700;color:#fff;line-height:1.2;white-space:nowrap}
.nav-brand-sub{font-size:10px;color:var(--purple-light);text-transform:uppercase;letter-spacing:0.8px}
.nav-sep{width:1px;height:26px;background:rgba(108,59,255,0.35);flex-shrink:0}
.nav-links{display:flex;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;flex:1}
.nav-links::-webkit-scrollbar{display:none}
.nav-links a{font-size:11.5px;font-weight:500;color:rgba(255,255,255,0.6);padding:13px 11px;white-space:nowrap;border-bottom:2px solid transparent;transition:color .15s,border-color .15s}
.nav-links a:hover{color:#fff;border-bottom-color:var(--purple-bright)}
.nav-cta{flex-shrink:0;background:var(--purple-bright);color:#fff;font-size:12px;font-weight:700;padding:7px 16px;border-radius:50px;white-space:nowrap;transition:background .15s}
.nav-cta:hover{background:var(--purple-accent)}

/* ── HERO ── */
.hero{background:linear-gradient(160deg,#1a0a4a 0%,#0e0630 50%,#150840 100%);position:relative;overflow:hidden;padding:72px 1.25rem 80px}
.hero::before{content:'';position:absolute;top:-120px;right:-80px;width:600px;height:600px;background:radial-gradient(circle,rgba(108,59,255,0.18) 0%,transparent 70%);pointer-events:none}
.hero::after{content:'';position:absolute;bottom:-80px;left:-60px;width:400px;height:400px;background:radial-gradient(circle,rgba(0,212,200,0.08) 0%,transparent 70%);pointer-events:none}
.hero-inner{max-width:1220px;margin:0 auto;position:relative}
.hero-pills{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:1.25rem}
.pill{display:inline-flex;align-items:center;font-size:11px;font-weight:700;padding:4px 12px;border-radius:50px;letter-spacing:0.4px;text-transform:uppercase}
.pill-purple{background:rgba(108,59,255,0.25);color:var(--purple-light);border:1px solid rgba(108,59,255,0.45)}
.pill-teal{background:rgba(0,212,200,0.15);color:var(--teal);border:1px solid rgba(0,212,200,0.35)}
.pill-white{background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.7);border:1px solid rgba(255,255,255,0.18)}
.hero-label{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:var(--purple-light);opacity:0.7;margin-bottom:12px}
.hero h1{font-size:clamp(26px,4.5vw,52px);font-weight:800;color:#fff;line-height:1.1;margin-bottom:18px;max-width:820px}
.hero h1 em{font-style:normal;color:var(--purple-bright)}
.hero-desc{font-size:clamp(14px,2vw,17px);color:rgba(255,255,255,0.7);max-width:660px;line-height:1.75;margin-bottom:2rem}
.hero-meta{display:flex;flex-wrap:wrap;gap:2rem;padding:1.5rem 0;border-top:1px solid rgba(255,255,255,0.1);border-bottom:1px solid rgba(255,255,255,0.1);margin-bottom:2rem}
.hm-item .hm-label{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,0.35);margin-bottom:4px}
.hm-item .hm-val{font-size:13px;font-weight:700;color:#fff}
.hero-ctas{display:flex;flex-wrap:wrap;gap:10px}
.btn{display:inline-flex;align-items:center;gap:6px;padding:11px 22px;border-radius:50px;font-size:13px;font-weight:700;transition:all .15s;border:none;cursor:pointer}
.btn-primary{background:var(--purple-bright);color:#fff}
.btn-primary:hover{background:var(--purple-accent);transform:translateY(-1px)}
.btn-teal{background:var(--teal);color:var(--purple-deep)}
.btn-teal:hover{opacity:0.9;transform:translateY(-1px)}
.btn-outline{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,0.3)}
.btn-outline:hover{border-color:#fff;background:rgba(255,255,255,0.06)}

/* ── SECTION WRAPPERS ── */
.sec-dark{background:linear-gradient(180deg,var(--purple-dark) 0%,var(--purple-deep) 100%);padding:5rem 1.25rem}
.sec-mid{background:var(--purple-mid);padding:5rem 1.25rem}
.sec-deepest{background:#09031e;padding:5rem 1.25rem}
.sec-white{background:#f8f7ff;padding:5rem 1.25rem}
.sec-inner{max-width:1220px;margin:0 auto}
.sec-eyebrow{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.8px;color:var(--purple-bright);margin-bottom:8px}
.sec-eyebrow-teal{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.8px;color:var(--teal);margin-bottom:8px}
.sec-title{font-size:clamp(22px,3.2vw,36px);font-weight:800;color:#fff;line-height:1.2;margin-bottom:12px}
.sec-title-dark{font-size:clamp(22px,3.2vw,36px);font-weight:800;color:var(--text-dark);line-height:1.2;margin-bottom:12px}
.sec-title em{font-style:normal;color:var(--purple-bright)}
.sec-body{font-size:15px;color:rgba(255,255,255,0.65);max-width:700px;line-height:1.8;margin-bottom:2.5rem}
.sec-body-dark{font-size:15px;color:var(--text-muted);max-width:700px;line-height:1.8;margin-bottom:2.5rem}

/* ── GRIDS ── */
.g2{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.ga{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:18px}
.ga-sm{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px}

/* ── WHITE CARDS ── */
.wcard{background:var(--card-bg);border-radius:var(--radius-lg);padding:1.5rem;box-shadow:var(--shadow);transition:box-shadow .2s,transform .2s;border:1px solid var(--card-border)}
.wcard:hover{box-shadow:var(--shadow-hover);transform:translateY(-3px)}
.wcard-title{font-size:15px;font-weight:700;color:var(--purple-bright);margin-bottom:8px;line-height:1.35}
.wcard-body{font-size:13.5px;color:var(--text-muted);line-height:1.7}

/* ── STAT CARDS (overview) ── */
.scard{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:var(--radius);padding:1.25rem;border-top:3px solid var(--purple-bright)}
.scard .sl{font-size:10px;text-transform:uppercase;letter-spacing:0.8px;color:rgba(255,255,255,0.4);margin-bottom:6px}
.scard .sv{font-size:15px;font-weight:700;color:#fff}

/* ── AUDIENCE ── */
.acard{background:var(--card-bg);border-radius:var(--radius);padding:1.1rem 1.25rem;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow);transition:box-shadow .15s,transform .15s;border:1px solid var(--card-border)}
.acard:hover{box-shadow:var(--shadow-hover);transform:translateY(-2px)}
.aicon{width:40px;height:40px;border-radius:var(--radius);background:linear-gradient(135deg,#ede9fe,#ddd6fe);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.aabbr{font-size:10px;font-weight:700;color:var(--purple-bright);text-transform:uppercase;letter-spacing:0.4px;margin-bottom:1px}
.atitle{font-size:13px;font-weight:700;color:var(--text-dark)}

/* ── CHALLENGE CARDS ── */
.chal-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);border-radius:var(--radius-lg);padding:1.6rem;transition:background .15s}
.chal-card:hover{background:rgba(108,59,255,0.12)}
.chal-num{font-size:11px;font-weight:800;color:var(--purple-bright);letter-spacing:1px;text-transform:uppercase;margin-bottom:10px}
.chal-bar{width:28px;height:3px;background:var(--purple-bright);border-radius:2px;margin-bottom:14px}
.chal-title{font-size:16px;font-weight:800;color:#fff;margin-bottom:9px}
.chal-desc{font-size:13px;color:rgba(255,255,255,0.58);line-height:1.7}

/* ── MESSAGING ── */
.mcard{background:var(--card-bg);border-radius:var(--radius-lg);padding:1.75rem;box-shadow:var(--shadow);border-top:4px solid var(--purple-bright);transition:box-shadow .2s,transform .2s}
.mcard:hover{box-shadow:var(--shadow-hover);transform:translateY(-2px)}
.mnum{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--purple-bright);margin-bottom:10px}
.mtitle{font-size:15px;font-weight:800;color:var(--text-dark);margin-bottom:10px;line-height:1.35}
.mdesc{font-size:13.5px;color:var(--text-muted);line-height:1.72}

/* ── BIG STAT SECTION ── */
.stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;text-align:center}
.stat-item{padding:2.5rem 1.5rem;border-right:1px solid rgba(255,255,255,0.1)}
.stat-item:last-child{border-right:none}
.stat-item.featured{background:rgba(108,59,255,0.2);border:1px solid rgba(108,59,255,0.4);border-radius:var(--radius-lg);margin:-4px}
.stat-num{font-size:clamp(36px,5vw,60px);font-weight:900;color:#fff;line-height:1;margin-bottom:10px}
.stat-label{font-size:13px;color:rgba(255,255,255,0.65);line-height:1.5;max-width:200px;margin:0 auto}
.stat-wrap{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-top:2.5rem}

/* ── FUNNEL ── */
.funnel-row{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius);padding:1.1rem 1.25rem;display:grid;grid-template-columns:130px 72px 1fr;gap:12px;align-items:start;transition:background .15s}
.funnel-row:hover{background:rgba(108,59,255,0.12)}
.f-stage{font-size:14px;font-weight:800;color:#fff}
.ftag{display:inline-block;padding:3px 10px;border-radius:50px;font-size:10.5px;font-weight:700}
.ft-tofu{background:rgba(0,212,200,0.15);color:var(--teal);border:1px solid rgba(0,212,200,0.3)}
.ft-mofu{background:rgba(251,191,36,0.15);color:#fbbf24;border:1px solid rgba(251,191,36,0.3)}
.ft-bofu{background:rgba(108,59,255,0.25);color:var(--purple-light);border:1px solid rgba(108,59,255,0.4)}
.f-content{font-size:13px;color:rgba(255,255,255,0.65);line-height:1.6}
.f-content strong{color:#fff;font-weight:600}
.f-goal{margin-top:5px;font-size:12px;color:var(--purple-bright);font-weight:600}

/* ── REGIONAL ── */
.rcard{border-radius:var(--radius-lg);overflow:hidden;background:var(--card-bg);box-shadow:var(--shadow)}
.rhead{padding:1.1rem 1.4rem;display:flex;align-items:center;gap:10px}
.rh-eu{background:linear-gradient(135deg,#1a0a4a,#2d1580)}
.rh-ap{background:linear-gradient(135deg,#09031e,#0f5a50)}
.rh-am{background:linear-gradient(135deg,#2d1580,#1a0a4a)}
.rname{font-size:15px;font-weight:800;color:#fff}
.rflag{font-size:20px}
.rbody{padding:1.25rem 1.4rem}
.rfocus-label{font-size:10px;text-transform:uppercase;letter-spacing:0.8px;color:var(--text-muted);margin-bottom:6px;margin-top:12px}
.rfocus-label:first-child{margin-top:0}
.rtags{display:flex;flex-wrap:wrap;gap:5px}
.rtag{font-size:11.5px;background:#f3f0ff;color:var(--purple-mid);border:1px solid #e0d9ff;border-radius:4px;padding:3px 8px;font-weight:500}
.rtip{margin-top:12px;font-size:12.5px;color:var(--text-muted);background:#f3f0ff;border-left:3px solid var(--purple-bright);border-radius:0 4px 4px 0;padding:9px 12px;font-style:italic;line-height:1.55}

/* ── CONTENT CARDS ── */
.cc{background:var(--card-bg);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow);transition:box-shadow .2s,transform .2s;display:flex;flex-direction:column;border:1px solid var(--card-border)}
.cc:hover{box-shadow:var(--shadow-hover);transform:translateY(-3px)}
.cc-img{width:100%;height:148px;object-fit:cover;background:#1a0a4a}
.cc-ph{width:100%;height:148px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#3d22a0 0%,#6c3bff 60%,#2d1580 100%);position:relative;overflow:hidden}
.cc-ph::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 30%,rgba(0,212,200,0.18) 0%,transparent 65%)}
.cc-ph span{font-size:12px;color:rgba(255,255,255,0.75);text-align:center;padding:0 1.5rem;font-weight:600;letter-spacing:0.3px;position:relative;z-index:1}
.cc-body{padding:1.1rem;display:flex;flex-direction:column;flex:1}
.cctags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px}
.cctag{font-size:10px;font-weight:700;padding:2px 8px;border-radius:50px;text-transform:uppercase;letter-spacing:0.3px}
.t-lp{background:#ede9fe;color:#4c1d95}
.t-blog{background:#dbeafe;color:#1e40af}
.t-case{background:#dcfce7;color:#166534}
.t-video{background:#fef3c7;color:#92400e}
.t-kh{background:#ede9fe;color:var(--purple-mid)}
.t-tofu{background:rgba(0,212,200,0.12);color:#0f766e}
.t-mofu{background:#fef3c7;color:#92400e}
.t-bofu{background:#ede9fe;color:#4c1d95}
.cc-title{font-size:13.5px;font-weight:700;color:var(--text-dark);margin-bottom:7px;line-height:1.4}
.cc-desc{font-size:12.5px;color:var(--text-muted);line-height:1.62;flex:1;margin-bottom:12px}
.cc-btn{align-self:flex-start;font-size:12px;font-weight:700;color:var(--purple-bright);border:1.5px solid var(--purple-bright);padding:5px 14px;border-radius:50px;transition:all .15s}
.cc-btn:hover{background:var(--purple-bright);color:#fff}

/* dark variant */
.cc-dark{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1)}
.cc-dark .cc-title{color:#fff}
.cc-dark .cc-desc{color:rgba(255,255,255,0.58)}
.cc-dark .cc-btn{color:var(--teal);border-color:var(--teal)}
.cc-dark .cc-btn:hover{background:var(--teal);color:var(--purple-deep)}

/* ── NURTURE ── */
.ncard{background:var(--card-bg);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow)}
.nhead{padding:1rem 1.25rem;display:flex;align-items:center;justify-content:space-between}
.nh-t{background:linear-gradient(135deg,#2d1580,var(--purple-bright))}
.nh-m{background:linear-gradient(135deg,#92400e,#d97706)}
.nh-b{background:linear-gradient(135deg,#1a0a4a,#2d1580)}
.nlabel{font-size:15px;font-weight:800;color:#fff}
.nbadge{font-size:10px;background:rgba(255,255,255,0.2);color:#fff;padding:3px 10px;border-radius:50px;font-weight:600}
.nbody{padding:1.1rem 1.25rem}
.nst{font-size:10px;text-transform:uppercase;letter-spacing:0.8px;color:var(--text-muted);margin-bottom:5px;margin-top:12px}
.nst:first-child{margin-top:0}
.npurpose{font-size:13px;color:var(--text-muted);line-height:1.62}
.nlist{list-style:none;padding:0}
.nlist li{font-size:12.5px;color:var(--text-muted);padding:3px 0;display:flex;gap:6px}
.nlist li::before{content:'›';color:var(--purple-bright);font-weight:700;flex-shrink:0;line-height:1.6}
.triggers{display:flex;flex-wrap:wrap;gap:5px;margin-top:4px}
.trig{font-size:11.5px;background:#f3f0ff;color:var(--purple-mid);border:1px solid #e0d9ff;border-radius:4px;padding:2px 8px;font-weight:500}

/* ── SHAREPOINT ── */
.spcard{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.09);border-radius:var(--radius);padding:1.25rem;transition:background .15s}
.spcard:hover{background:rgba(108,59,255,0.15)}
.spico{width:38px;height:38px;border-radius:var(--radius);background:rgba(108,59,255,0.25);display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:10px}
.spname{font-size:14px;font-weight:800;color:#fff;margin-bottom:5px}
.spdesc{font-size:12.5px;color:rgba(255,255,255,0.5);margin-bottom:12px;line-height:1.55}
.spbtn{display:inline-block;font-size:11.5px;font-weight:700;color:var(--purple-light);border:1px solid rgba(139,92,246,0.5);padding:5px 12px;border-radius:50px;transition:all .15s}
.spbtn:hover{background:rgba(108,59,255,0.2);border-color:var(--purple-accent)}

/* ── CTA FOOTER ── */
.cta-sec{background:linear-gradient(135deg,#2d1580,var(--purple-bright));padding:5rem 1.25rem;text-align:center}
.cta-inner{max-width:720px;margin:0 auto}
.cta-inner h2{font-size:clamp(22px,3vw,34px);font-weight:800;color:#fff;margin-bottom:12px}
.cta-inner p{font-size:15px;color:rgba(255,255,255,0.8);line-height:1.75;margin-bottom:2rem}
.cta-btns{display:flex;flex-wrap:wrap;justify-content:center;gap:12px}
.btn-white{background:#fff;color:var(--purple-mid);font-weight:800}
.btn-white:hover{background:#f3f0ff}
.cta-note{margin-top:1.5rem;font-size:12.5px;color:rgba(255,255,255,0.5)}

/* ── MOBILE ── */
@media(max-width:768px){
  .nav-cta{display:none}
  .sec-dark,.sec-mid,.sec-deepest,.sec-white,.cta-sec{padding:2.75rem 1rem}
  .hero{padding:2.5rem 1rem 3rem}
  .g2,.g3,.g4{grid-template-columns:1fr}
  .ga{grid-template-columns:1fr}
  .ga-sm{grid-template-columns:repeat(2,1fr)}
  .stat-grid,.stat-wrap{grid-template-columns:1fr;gap:1rem}
  .stat-item{border-right:none;border-bottom:1px solid rgba(255,255,255,0.1);padding:1.5rem 1rem}
  .stat-item:last-child{border-bottom:none}
  .stat-item.featured{margin:0;border-radius:var(--radius)}
  .funnel-row{grid-template-columns:1fr;gap:6px}
}
@media(max-width:480px){
  .ga-sm{grid-template-columns:1fr}
  .hero h1{font-size:24px}
  .hero-meta{gap:1.25rem}
  .hm-val{font-size:12px}
}
</style>
</head>
